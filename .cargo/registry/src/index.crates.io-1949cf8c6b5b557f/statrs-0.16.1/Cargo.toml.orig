[package]

name = "statrs"
version = "0.16.1"
authors = ["Michael Ma"]
description = "Statistical computing library for Rust"
license = "MIT"
keywords = ["probability", "statistics", "stats", "distribution", "math"]
categories = ["science"]
homepage = "https://github.com/statrs-dev/statrs"
repository = "https://github.com/statrs-dev/statrs"
edition = "2018"

include = ["CHANGELOG.md", "LICENSE.md", "src/", "benches"]

[lib]
name = "statrs"
path = "src/lib.rs"

[features]
nightly = []

[dependencies]
rand = "0.8"
nalgebra = { version = "0.29", features = ["rand"] }
approx = "0.5.0"
num-traits = "0.2.14"
lazy_static = "1.4.0"

[dev-dependencies]
criterion = "0.3.3"

[[bench]]
name = "order_statistics"
harness = false
